---

<div id="adblock-notice" class="adblock-notice" role="status" aria-live="polite" style="display:none;">
  <div class="adblock-notice-inner">
    <span>
      👋 Looks like you're using an ad blocker. Bracketly stays free thanks to a single,
      unobtrusive ad per page — no popups, no autoplay video, no spam, ever. If you're able,
      click your ad blocker's icon in the browser toolbar and choose "allowlist this site" —
      it genuinely helps keep the tools free. Thanks either way!
    </span>
    <button id="adblock-dismiss" class="adblock-dismiss" aria-label="Dismiss this message">×</button>
  </div>
</div>

<style>
  .adblock-notice {
    position: fixed;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    z-index: 200;
    max-width: 32rem;
    margin: 0 auto;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lift);
    animation: fadeInUp 0.4s ease both;
  }
  .adblock-notice-inner {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.1rem;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text);
  }
  .adblock-dismiss {
    flex-shrink: 0;
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 1.2rem;
    line-height: 1;
    cursor: pointer;
    padding: 0;
  }
  .adblock-dismiss:hover {
    color: var(--text);
  }
  @media (max-width: 480px) {
    .adblock-notice-inner {
      font-size: 0.8rem;
    }
  }
</style>

<script is:inline>
  (function () {
    var STORAGE_KEY = 'bracketly-adblock-dismissed';
    try {
      if (localStorage.getItem(STORAGE_KEY)) return;
    } catch (e) {
      return;
    }

    var bait = document.createElement('div');
    bait.className = 'adsbygoogle adsbox ad-banner ad-placement';
    bait.style.cssText = 'position:absolute;top:-9999px;left:-9999px;width:300px;height:250px;';
    document.body.appendChild(bait);

    setTimeout(function () {
      // Two independent signals, since blockers work two different ways:
      // cosmetic filters hide the bait div via CSS, network-level blockers
      // instead stop the real AdSense script from ever loading at all.
      var cosmeticBlock =
        bait.offsetHeight === 0 ||
        bait.clientHeight === 0 ||
        getComputedStyle(bait).display === 'none';
      var networkBlock = window.__bracketlyAdsFailed === true;
      document.body.removeChild(bait);
      var blocked = cosmeticBlock || networkBlock;
      if (!blocked) return;

      var notice = document.getElementById('adblock-notice');
      if (!notice) return;
      notice.style.display = 'block';

      var dismiss = document.getElementById('adblock-dismiss');
      dismiss.addEventListener('click', function () {
        notice.style.display = 'none';
        try {
          localStorage.setItem(STORAGE_KEY, '1');
        } catch (e) {}
      });
    }, 800);
  })();
</script>
