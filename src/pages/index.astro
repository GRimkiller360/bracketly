---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdUnit from '../components/AdUnit.astro';
import { tools, getCategoryColor } from '../data/tools';

const categories = [...new Set(tools.map((t) => t.category))];
---

<BaseLayout
  title="Free Developer Tools"
  description="Fast, free, privacy-first developer utilities. JSON formatter, Base64 encoder, JWT decoder, UUID generator, Regex tester and more — all run entirely in your browser."
  keywords="developer tools, json formatter online, base64 encoder, jwt decoder, uuid generator, regex tester, unix timestamp converter"
>
  <div class="container">
    <div class="hero">
      <span class="pill" style="margin-bottom:0.9rem;">✦ {tools.length} free tools, 100% client-side</span>
      <h1>Free Developer Tools</h1>
      <p>
        Fast, privacy-first utilities for developers. Everything runs in your browser —
        nothing you enter is ever sent to a server.
      </p>
      <input
        type="search"
        id="tool-search"
        class="tool-search"
        placeholder="Search tools…"
        aria-label="Search tools"
        autocomplete="off"
      />
    </div>

    <AdUnit />

    <div id="tool-sections">
      {
        categories.map((cat) => {
          const c = getCategoryColor(cat);
          return (
            <section class="tool-section" data-category={cat} style="margin-bottom:2.5rem;">
              <h2
                class="category-label"
                style={`--card-accent-light:${c.light};--card-accent-dark:${c.dark};`}
              >
                {cat}
              </h2>
              <div class="tool-grid">
                {tools
                  .filter((t) => t.category === cat)
                  .map((tool) => (
                    <a
                      href={`/tools/${tool.slug}`}
                      class="tool-card"
                      data-search={`${tool.title} ${tool.shortTitle} ${tool.description} ${tool.category}`.toLowerCase()}
                      style={`--card-accent-light:${c.light};--card-accent-dark:${c.dark};`}
                    >
                      <div class="icon">{tool.icon}</div>
                      <h3>{tool.shortTitle}</h3>
                      <p>{tool.description.split('.')[0]}.</p>
                    </a>
                  ))}
              </div>
            </section>
          );
        })
      }
    </div>
    <p id="tool-search-empty" class="tool-search-empty" role="status">
      No tools match your search.
    </p>

    <script is:inline>
      (function () {
        var input = document.getElementById('tool-search');
        var sections = document.querySelectorAll('.tool-section');
        var empty = document.getElementById('tool-search-empty');
        if (!input) return;

        input.addEventListener('input', function () {
          var query = input.value.trim().toLowerCase();
          var anyVisible = false;

          sections.forEach(function (section) {
            var cards = section.querySelectorAll('.tool-card');
            var sectionHasMatch = false;
            cards.forEach(function (card) {
              var matches = !query || card.dataset.search.indexOf(query) !== -1;
              card.style.display = matches ? '' : 'none';
              if (matches) sectionHasMatch = true;
            });
            section.style.display = sectionHasMatch ? '' : 'none';
            if (sectionHasMatch) anyVisible = true;
          });

          empty.style.display = anyVisible ? 'none' : 'block';
        });
      })();
    </script>

    <div class="panel" style="text-align:center;padding:2.25rem;margin-top:0.5rem;position:relative;overflow:hidden;">
      <p style="margin:0 0 1rem;font-size:1.05rem;">
        Bracketly is free and open-source. If it saves you time, consider supporting it.
      </p>
      <a href="/donate" class="btn btn-support" style="font-size:1rem;padding:0.65rem 1.4rem;">
        ☕ Buy me a coffee
      </a>
    </div>

    <div class="panel" style="margin-top:1.5rem;">
      <h2 style="margin:0 0 0.35rem;font-size:1.05rem;">Recommended resources</h2>
      <p style="color:var(--text-muted);margin:0 0 1rem;font-size:0.9rem;">
        A few other free resources developers tend to reach for. Not sponsored — just genuinely useful.
      </p>
      <ul style="color:var(--text-muted);font-size:0.92rem;margin:0;padding-left:1.25rem;line-height:1.9;">
        <li>
          <a href="https://developer.mozilla.org/" target="_blank" rel="noopener noreferrer">MDN Web Docs</a>
          {" "}— the reference for HTML, CSS, and JavaScript.
        </li>
        <li>
          <a href="https://devdocs.io/" target="_blank" rel="noopener noreferrer">DevDocs</a>
          {" "}— fast, searchable API docs for dozens of languages and frameworks in one place.
        </li>
        <li>
          <a href="https://caniuse.com/" target="_blank" rel="noopener noreferrer">Can I Use</a>
          {" "}— browser support tables for web platform features.
        </li>
      </ul>
    </div>
  </div>
</BaseLayout>
