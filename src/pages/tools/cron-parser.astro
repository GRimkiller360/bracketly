---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getTool } from '../../data/tools';

const tool = getTool('cron-parser')!;
---

<ToolLayout tool={tool}>
  <div class="panel" style="margin-bottom:1rem;">
    <div class="field-label">
      <span>Cron expression</span>
    </div>
    <input
      id="cron-input"
      type="text"
      placeholder="*/15 * * * *"
      value="*/15 * * * *"
    />
    <div class="toolbar">
      <button class="btn" data-example="* * * * *">Every minute</button>
      <button class="btn" data-example="0 * * * *">Hourly</button>
      <button class="btn" data-example="0 0 * * *">Daily at midnight</button>
      <button class="btn" data-example="0 9 * * 1-5">Weekdays at 9am</button>
      <button class="btn" data-example="0 0 1 * *">Monthly</button>
    </div>
    <div id="cron-status" class="status" role="status" aria-live="polite" style="margin-top:0.4rem;"></div>
  </div>

  <div class="panel" id="cron-summary-panel" style="margin-bottom:1rem;display:none;">
    <div class="field-label"><span>What it means</span></div>
    <p id="cron-summary" aria-live="polite" style="margin:0;font-size:1rem;font-weight:600;"></p>
  </div>

  <div class="panel" id="cron-next-panel" style="display:none;">
    <div class="field-label">
      <span>Next 5 run times</span>
      <button class="btn" id="btn-copy-cron" aria-label="Copy next run times" style="padding:0.2rem 0.6rem;font-size:0.75rem;">Copy</button>
    </div>
    <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
      <tbody id="cron-next-table"></tbody>
    </table>
  </div>
</ToolLayout>

<style>
  #cron-next-table tr td {
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  #cron-next-table tr td:first-child {
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-weight: 600;
    white-space: nowrap;
    width: 90px;
  }
</style>

<script is:inline>
  var SHORTCUTS = {
    '@yearly': '0 0 1 1 *',
    '@annually': '0 0 1 1 *',
    '@monthly': '0 0 1 * *',
    '@weekly': '0 0 * * 0',
    '@daily': '0 0 * * *',
    '@midnight': '0 0 * * *',
    '@hourly': '0 * * * *',
  };

  function parseField(field, min, max) {
    var result = {};
    var parts = field.split(',');
    for (var p = 0; p < parts.length; p++) {
      var part = parts[p];
      var stepSplit = part.split('/');
      var base = stepSplit[0];
      var step = 1;
      if (stepSplit.length > 1) {
        step = parseInt(stepSplit[1], 10);
        if (isNaN(step) || step <= 0) throw new Error('Invalid step in "' + part + '"');
      } else if (stepSplit.length > 2) {
        throw new Error('Invalid field "' + part + '"');
      }
      var rangeStart, rangeEnd;
      if (base === '*') {
        rangeStart = min; rangeEnd = max;
      } else if (base.indexOf('-') !== -1) {
        var rp = base.split('-');
        if (rp.length !== 2) throw new Error('Invalid range "' + base + '"');
        rangeStart = parseInt(rp[0], 10);
        rangeEnd = parseInt(rp[1], 10);
        if (isNaN(rangeStart) || isNaN(rangeEnd)) throw new Error('Invalid range "' + base + '"');
      } else {
        rangeStart = rangeEnd = parseInt(base, 10);
        if (isNaN(rangeStart)) throw new Error('Invalid value "' + base + '"');
      }
      if (rangeStart < min || rangeEnd > max || rangeStart > rangeEnd) {
        throw new Error('Value out of range in "' + part + '" (expected ' + min + '-' + max + ')');
      }
      for (var v = rangeStart; v <= rangeEnd; v += step) {
        result[v] = true;
      }
    }
    return result;
  }

  function parseCron(expr) {
    var trimmed = expr.trim();
    if (SHORTCUTS[trimmed]) trimmed = SHORTCUTS[trimmed];
    var fields = trimmed.split(/\s+/);
    if (fields.length !== 5) {
      throw new Error('Expected 5 fields (minute hour day month weekday), got ' + fields.length);
    }
    var minute = parseField(fields[0], 0, 59);
    var hour = parseField(fields[1], 0, 23);
    var dom = parseField(fields[2], 1, 31);
    var month = parseField(fields[3], 1, 12);
    var dow = parseField(fields[4], 0, 7);
    if (dow[7]) { dow[0] = true; delete dow[7]; }
    return {
      minute: minute, hour: hour, dom: dom, month: month, dow: dow,
      domIsWildcard: fields[2] === '*', dowIsWildcard: fields[4] === '*',
    };
  }

  function matchesDate(parsed, date) {
    var min = date.getMinutes();
    var hr = date.getHours();
    var day = date.getDate();
    var mon = date.getMonth() + 1;
    var wday = date.getDay();
    if (!parsed.minute[min]) return false;
    if (!parsed.hour[hr]) return false;
    if (!parsed.month[mon]) return false;
    var domMatch = !!parsed.dom[day];
    var dowMatch = !!parsed.dow[wday];
    if (parsed.domIsWildcard && parsed.dowIsWildcard) return true;
    if (parsed.domIsWildcard) return dowMatch;
    if (parsed.dowIsWildcard) return domMatch;
    return domMatch || dowMatch;
  }

  function nextRuns(parsed, from, count, maxMinutes) {
    var results = [];
    var cur = new Date(from.getTime());
    cur.setSeconds(0, 0);
    cur.setMinutes(cur.getMinutes() + 1);
    var iterations = 0;
    while (results.length < count && iterations < maxMinutes) {
      if (matchesDate(parsed, cur)) {
        results.push(new Date(cur.getTime()));
      }
      cur.setMinutes(cur.getMinutes() + 1);
      iterations++;
    }
    return results;
  }

  var WEEKDAY_NAMES = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
  var MONTH_NAMES = ['', 'January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

  function setToSortedArray(set) {
    return Object.keys(set).map(Number).sort(function (a, b) { return a - b; });
  }

  function isFullRange(set, min, max) {
    for (var i = min; i <= max; i++) if (!set[i]) return false;
    return true;
  }

  function detectUniformStep(set, min, max) {
    var arr = setToSortedArray(set);
    if (arr.length < 2) return null;
    var step = arr[1] - arr[0];
    if (arr[0] !== min) return null;
    for (var i = 1; i < arr.length; i++) {
      if (arr[i] - arr[i - 1] !== step) return null;
    }
    var last = arr[arr.length - 1];
    if (last + step <= max) return null;
    return step;
  }

  function describeRanges(arr, names) {
    var label = function (v) { return names ? names[v] : String(v); };
    var parts = [];
    var i = 0;
    while (i < arr.length) {
      var start = arr[i];
      var end = start;
      while (i + 1 < arr.length && arr[i + 1] === end + 1) {
        end = arr[++i];
      }
      if (end - start >= 2) {
        parts.push(label(start) + '-' + label(end));
      } else if (end !== start) {
        parts.push(label(start) + ', ' + label(end));
      } else {
        parts.push(label(start));
      }
      i++;
    }
    return parts.join(', ');
  }

  function describeCron(parsed) {
    var minuteFull = isFullRange(parsed.minute, 0, 59);
    var hourFull = isFullRange(parsed.hour, 0, 23);
    var minuteArr = setToSortedArray(parsed.minute);
    var hourArr = setToSortedArray(parsed.hour);

    var minuteStep = detectUniformStep(parsed.minute, 0, 59);
    var hourStep = detectUniformStep(parsed.hour, 0, 23);

    var timeClause;
    if (minuteFull && hourFull) {
      timeClause = 'Every minute';
    } else if (minuteStep && hourFull) {
      timeClause = 'Every ' + minuteStep + ' minute' + (minuteStep === 1 ? '' : 's');
    } else if (minuteArr.length === 1 && hourFull) {
      timeClause = 'At minute ' + minuteArr[0] + ' past every hour';
    } else if (minuteFull && hourArr.length > 0 && !hourFull) {
      timeClause = 'Every minute, during hour ' + describeRanges(hourArr);
    } else if (minuteArr.length === 1 && hourArr.length === 1) {
      timeClause = 'At ' + String(hourArr[0]).padStart(2, '0') + ':' + String(minuteArr[0]).padStart(2, '0');
    } else if (hourStep && minuteArr.length === 1) {
      timeClause = 'At minute ' + minuteArr[0] + ', every ' + hourStep + ' hour' + (hourStep === 1 ? '' : 's');
    } else {
      timeClause = 'At minute ' + describeRanges(minuteArr) + ' past hour ' + describeRanges(hourArr);
    }

    var clauses = [timeClause];

    var domClause = parsed.domIsWildcard ? null : 'on day-of-month ' + describeRanges(setToSortedArray(parsed.dom));
    var dowClause = parsed.dowIsWildcard ? null : 'on ' + describeRanges(setToSortedArray(parsed.dow), WEEKDAY_NAMES);

    if (domClause && dowClause) {
      clauses.push(domClause + ' or ' + dowClause);
    } else if (domClause) {
      clauses.push(domClause);
    } else if (dowClause) {
      clauses.push(dowClause);
    }

    if (!isFullRange(parsed.month, 1, 12)) {
      clauses.push('in ' + describeRanges(setToSortedArray(parsed.month), MONTH_NAMES));
    }

    return clauses.join(', ');
  }

  var lastRows = null;
  var debounceTimer = null;

  function render() {
    var raw = document.getElementById('cron-input').value;
    var status = document.getElementById('cron-status');
    var summaryPanel = document.getElementById('cron-summary-panel');
    var nextPanel = document.getElementById('cron-next-panel');

    if (!raw.trim()) {
      status.textContent = '';
      summaryPanel.style.display = 'none';
      nextPanel.style.display = 'none';
      return;
    }

    var parsed;
    try {
      parsed = parseCron(raw);
    } catch (e) {
      status.textContent = '✗ ' + e.message;
      status.className = 'status error';
      summaryPanel.style.display = 'none';
      nextPanel.style.display = 'none';
      return;
    }

    status.textContent = '';
    status.className = 'status';

    document.getElementById('cron-summary').textContent = describeCron(parsed);
    summaryPanel.style.display = 'block';

    var runs = nextRuns(parsed, new Date(), 5, 2 * 366 * 24 * 60);
    if (runs.length === 0) {
      document.getElementById('cron-summary').textContent += ' — but no matching time was found in the next 2 years (check your day-of-month/month combination).';
      nextPanel.style.display = 'none';
      return;
    }

    var rows = runs.map(function (d, i) {
      return ['#' + (i + 1), d.toLocaleString()];
    });
    var tbody = document.getElementById('cron-next-table');
    tbody.innerHTML = rows.map(function (r) {
      return '<tr><td>' + r[0] + '</td><td>' + r[1] + '</td></tr>';
    }).join('');
    lastRows = rows;
    nextPanel.style.display = 'block';
  }

  document.getElementById('cron-input').addEventListener('input', function () {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(render, 200);
  });

  document.querySelectorAll('[data-example]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.getElementById('cron-input').value = btn.getAttribute('data-example');
      render();
    });
  });

  document.getElementById('btn-copy-cron').addEventListener('click', function () {
    if (!lastRows) return;
    var text = lastRows.map(function (r) { return r[0] + ': ' + r[1]; }).join('\n');
    var btn = this;
    navigator.clipboard.writeText(text).then(function () {
      btn.textContent = 'Copied!';
      setTimeout(function () { btn.textContent = 'Copy'; }, 1500);
    }, function () {
      btn.textContent = 'Copy failed';
      setTimeout(function () { btn.textContent = 'Copy'; }, 1500);
    });
  });

  render();
</script>
