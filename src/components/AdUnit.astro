---
/*
  AdUnit — Google AdSense display ad, rendered on the homepage and every tool page.
  Publisher/slot IDs are live; see BaseLayout.astro for the loader script.
*/
---

<ins
  class="adsbygoogle"
  style="display:block;position:relative;width:100%;min-height:100px;margin:2rem 0;"
  data-ad-client="ca-pub-5868369279571926"
  data-ad-slot="8066491572"
  data-ad-format="auto"
  data-full-width-responsive="true"
></ins>
<script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
