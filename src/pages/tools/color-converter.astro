---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getTool } from '../../data/tools';

const tool = getTool('color-converter')!;
---

<ToolLayout tool={tool}>
  <div class="grid-2">
    <div>
      <div class="field-label"><span>Enter a color (HEX, RGB, or HSL)</span></div>
      <input type="text" id="input" placeholder="#3457d5, rgb(52,87,213), or hsl(228,66%,52%)" />
      <div id="status" class="status" role="status" aria-live="polite" style="margin-top:0.5rem;"></div>
    </div>
    <div>
      <div class="field-label"><span>Preview</span></div>
      <div id="swatch" style="height:2.6rem;border-radius:8px;border:1px solid var(--border);"></div>
    </div>
  </div>

  <div style="margin-top:1.25rem;display:flex;flex-direction:column;gap:0.75rem;">
    {["HEX", "RGB", "HSL"].map((fmt) => (
      <div class="panel">
        <div class="field-label">
          <span>{fmt}</span>
          <button class="btn btn-copy-color" data-target={`out-${fmt}`} aria-label={`Copy ${fmt} value`} style="padding:0.2rem 0.5rem;font-size:0.75rem;">Copy</button>
        </div>
        <input type="text" id={`out-${fmt}`} readonly />
      </div>
    ))}
  </div>
</ToolLayout>

<script is:inline>
  const input = document.getElementById('input');
  const status = document.getElementById('status');
  const swatch = document.getElementById('swatch');
  const outHex = document.getElementById('out-HEX');
  const outRgb = document.getElementById('out-RGB');
  const outHsl = document.getElementById('out-HSL');

  function setStatus(msg, ok) {
    status.textContent = msg;
    status.className = 'status ' + (ok ? 'ok' : 'error');
  }

  function clamp(n, min, max) { return Math.min(max, Math.max(min, n)); }

  function parseColor(str) {
    str = str.trim();
    let m;
    if ((m = str.match(/^#?([0-9a-f]{6})$/i))) {
      const n = parseInt(m[1], 16);
      return { r: (n >> 16) & 255, g: (n >> 8) & 255, b: n & 255 };
    }
    if ((m = str.match(/^#?([0-9a-f]{3})$/i))) {
      const [r, g, b] = m[1].split('').map((c) => parseInt(c + c, 16));
      return { r, g, b };
    }
    if ((m = str.match(/^rgba?\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/i))) {
      return { r: clamp(+m[1], 0, 255), g: clamp(+m[2], 0, 255), b: clamp(+m[3], 0, 255) };
    }
    if ((m = str.match(/^hsla?\(\s*(\d+)\s*,\s*(\d+)%\s*,\s*(\d+)%/i))) {
      return hslToRgb(((+m[1] % 360) + 360) % 360, clamp(+m[2], 0, 100), clamp(+m[3], 0, 100));
    }
    return null;
  }

  function hslToRgb(h, s, l) {
    s /= 100; l /= 100;
    const c = (1 - Math.abs(2 * l - 1)) * s;
    const x = c * (1 - Math.abs(((h / 60) % 2) - 1));
    const m = l - c / 2;
    let [r, g, b] = h < 60 ? [c, x, 0] : h < 120 ? [x, c, 0] : h < 180 ? [0, c, x]
      : h < 240 ? [0, x, c] : h < 300 ? [x, 0, c] : [c, 0, x];
    return { r: Math.round((r + m) * 255), g: Math.round((g + m) * 255), b: Math.round((b + m) * 255) };
  }

  function rgbToHsl(r, g, b) {
    r /= 255; g /= 255; b /= 255;
    const max = Math.max(r, g, b), min = Math.min(r, g, b);
    let h, s, l = (max + min) / 2;
    if (max === min) { h = s = 0; }
    else {
      const d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      switch (max) {
        case r: h = (g - b) / d + (g < b ? 6 : 0); break;
        case g: h = (b - r) / d + 2; break;
        default: h = (r - g) / d + 4;
      }
      h *= 60;
    }
    return { h: Math.round(h), s: Math.round(s * 100), l: Math.round(l * 100) };
  }

  function toHex(n) { return n.toString(16).padStart(2, '0'); }

  function run() {
    const val = input.value;
    if (!val.trim()) {
      [outHex, outRgb, outHsl].forEach((el) => (el.value = ''));
      swatch.style.background = 'transparent';
      status.textContent = '';
      return;
    }
    const rgb = parseColor(val);
    if (!rgb) {
      setStatus('✗ Could not parse that as a color', false);
      return;
    }
    const { r, g, b } = rgb;
    const hsl = rgbToHsl(r, g, b);
    outHex.value = `#${toHex(r)}${toHex(g)}${toHex(b)}`;
    outRgb.value = `rgb(${r}, ${g}, ${b})`;
    outHsl.value = `hsl(${hsl.h}, ${hsl.s}%, ${hsl.l}%)`;
    swatch.style.background = outHex.value;
    setStatus('✓ Parsed', true);
  }

  input.addEventListener('input', run);

  document.querySelectorAll('.btn-copy-color').forEach((btn) => {
    btn.addEventListener('click', function () {
      const target = document.getElementById(this.dataset.target);
      if (!target.value) return;
      const b = this;
      navigator.clipboard.writeText(target.value).then(function () {
        b.textContent = 'Copied!';
        setTimeout(function () { b.textContent = 'Copy'; }, 1500);
      }, function () {
        b.textContent = 'Copy failed';
        setTimeout(function () { b.textContent = 'Copy'; }, 1500);
      });
    });
  });

  input.value = '#3457d5';
  run();
</script>
